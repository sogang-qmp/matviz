&CONTROL
  calculation      = 'scf'
  prefix           = 'mapbbr3_ideal'
  pseudo_dir       = './'
  outdir           = './out'
  verbosity        = 'high'
  tprnfor          = .true.
  tstress          = .true.
/
&SYSTEM
  ibrav            = 1
  celldm(1)        = 11.183404
  nat              = 12
  ntyp             = 5
  ecutwfc          = 80
  ecutrho          = 320
  occupations      = 'fixed'
  input_dft        = 'PBESOL'
/
&ELECTRONS
  conv_thr         = 1.0d-12
  mixing_beta      = 0.3
  electron_maxstep = 200
  diagonalization  = 'david'
/
ATOMIC_SPECIES
  Pb  207.2    Pb.upf
  Br   79.904  Br.upf
  C    12.011  C.upf
  N    14.007  N.upf
  H     1.008  H.upf

